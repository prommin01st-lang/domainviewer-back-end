meta {
  name: Delete Allowed Domain
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/api/allowedemaildomains/{{allowedDomainId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

tests {
  test("should return 200", function() {
    expect(res.status).to.equal(200);
  });
  test("should have success true", function() {
    expect(res.body.success).to.equal(true);
  });
}
